# Reader database connection string (required).
# RDS: postgresql://user:pass@host:5432/dbname
# Local: postgresql://user:pass@localhost:5432/dbname?sslmode=disable
DATABASE_READER_URL=
PORT=8080
# Allowed frontend origin. Empty falls back to "*" (no credentials are used).
CORS_ORIGIN=
# sslmode applied only when DATABASE_READER_URL has no sslmode param.
# require = TLS without cert verify (mirrors node rejectUnauthorized:false).
# Use disable for local dev.
DB_SSLMODE=require
